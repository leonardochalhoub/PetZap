# ============================================================================
# Supabase (free tier — create project at https://supabase.com)
# ============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # SERVER ONLY — never ship to client

# ============================================================================
# Google Gemini (free tier — create key at https://aistudio.google.com/apikey)
# ============================================================================
GEMINI_API_KEY=

# ============================================================================
# Meta WhatsApp Business Cloud API (free first 1000 service convos/mo)
# Set up at https://developers.facebook.com/ → My Apps → WhatsApp
# ============================================================================
META_VERIFY_TOKEN=pick-any-random-string-and-paste-the-same-in-meta-console
META_APP_SECRET=                  # from App Settings → Basic
META_PHONE_NUMBER_ID=             # from WhatsApp → API Setup
META_ACCESS_TOKEN=                # permanent System User token preferred

# ============================================================================
# App
# ============================================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
